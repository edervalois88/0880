# Base de Datos (Neon PostgreSQL para Producción / Local)
DATABASE_URL="postgresql://usuario:password@host:port/database?sslmode=require"

# Auth.js v5 (preferido) - Generar con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-aqui"

# Compatibilidad legado (opcional, no usar junto a AUTH_SECRET en nuevos entornos)
# NEXTAUTH_SECRET="tu-secreto-aqui"

# URL de la Aplicación (Solo necesaria en algunos entornos locales, Vercel la detecta automáticamente)
AUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Compatibilidad legado (opcional)
# NEXTAUTH_URL="http://localhost:3000"

# Entorno (development, production)
APP_ENV="development"

# Cloudinary (subida de imágenes de productos)
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
