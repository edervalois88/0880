# Base de Datos (Neon PostgreSQL para Producción / Local)
DATABASE_URL="postgresql://usuario:password@host:port/database?sslmode=require"

# NextAuth v5 (Auth.js) - Generar con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-aqui"

# URL de la Aplicación (Solo necesaria en algunos entornos locales, Vercel la detecta automáticamente)
AUTH_URL="http://localhost:3000"

# Entorno (development, production)
APP_ENV="development"
